{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dashboard.json",
  "title": "Dashboard MongoDB types",
  "description": "Dashboard and parameter models",
  "$defs": {
    "DefaultDashboard": {
      "title": "DefaultDashboard",
      "type": "string",
      "enum": ["summary", "trends", "empty"]
    },
    "ParameterType": {
      "title": "ParameterType",
      "type": "string",
      "enum": ["month", "year", "date_range", "select", "multi", "toggle", "number", "text"]
    },
    "ParameterOption": {
      "title": "ParameterOption",
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" }
      },
      "required": ["value", "label"]
    },
    "ParameterRequest": {
      "title": "ParameterRequest",
      "type": "object",
      "properties": {
        "type": { "type": "string", "default": "sql" },
        "assign_to": { "type": "string" },
        "query": { "type": "string" }
      },
      "required": ["assign_to", "query"]
    },
    "DashboardParameter": {
      "title": "DashboardParameter",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/ParameterType" },
        "default_value": { "default": null },
        "options": { "type": "array", "items": { "$ref": "#/$defs/ParameterOption" }, "default": [] },
        "min_value": { "default": null },
        "max_value": { "default": null },
        "value": { "default": null },
        "allow_all": { "type": "boolean", "default": false },
        "requests": { "type": "array", "items": { "$ref": "#/$defs/ParameterRequest" }, "default": [] },
        "last_requested": { "type": ["string", "null"], "format": "date-time", "default": null },
        "position": { "type": "integer", "default": 0 },
        "width": { "type": "string", "default": "auto" },
        "visible": { "type": "boolean", "default": true }
      },
      "required": ["id", "name", "type"]
    },
    "WidgetLayout": {
      "title": "WidgetLayout",
      "description": "Widget position on a 12-column dashboard grid",
      "type": "object",
      "properties": {
        "i": { "type": "string", "description": "Widget ID" },
        "x": { "type": "integer", "minimum": 0, "maximum": 11, "description": "Column position (0-11)" },
        "y": { "type": "integer", "minimum": 0, "description": "Row position" },
        "w": { "type": "integer", "minimum": 1, "maximum": 12, "description": "Width in grid columns (1-12)" },
        "h": { "type": "integer", "minimum": 1, "description": "Height in grid rows" },
        "color": { "type": "string", "default": "gray.50" },
        "accent": { "type": ["string", "null"], "default": null, "description": "Accent border color, e.g. 'green.500' or '#2F855A'" },
        "accent_position": { "type": ["string", "null"], "enum": ["top", "left", "right", "bottom", "all", null], "default": null, "description": "Which side to show the accent border" }
      },
      "required": ["i", "x", "y", "w", "h"]
    },
    "DDashboardBase": {
      "title": "DDashboardBase",
      "type": "object",
      "properties": {
        "version": { "type": "string", "default": "0.4" },
        "id": { "type": ["string", "null"], "default": null },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "icon": { "type": ["string", "null"], "default": "" },
        "project_id": { "type": "string", "default": "" },
        "layout": { "type": "array", "items": { "$ref": "#/$defs/WidgetLayout" } },
        "widgets": { "type": "array", "default": [] },
        "position_indx": { "type": "integer", "default": 0 },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/DashboardParameter" }, "default": [] },
        "parameter_values": { "type": "object", "default": {} }
      },
      "required": ["type", "title", "layout"]
    }
  }
}
