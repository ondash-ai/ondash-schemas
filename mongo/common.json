{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.json",
  "title": "Common MongoDB types",
  "description": "Shared types used across multiple collections: widgets, periods, table columns",
  "$defs": {
    "ColumnType": {
      "title": "ColumnType",
      "type": "string",
      "enum": ["text", "number", "currency", "percent", "date", "delta", "badge"]
    },
    "DWidgetType": {
      "title": "DWidgetType",
      "type": "string",
      "enum": ["metric", "statistic", "report", "text", "table", "echart", "markdown", "html"]
    },
    "PeriodConst": {
      "title": "PeriodConst",
      "type": "string",
      "enum": ["Month", "Quarter", "Half", "Year", "Unknown"]
    },
    "QuerySource": {
      "title": "QuerySource",
      "type": "object",
      "properties": {
        "type": { "type": "string", "default": "sql" },
        "template": { "type": "string", "default": "" },
        "parameters": { "type": ["object", "null"], "default": null }
      }
    },
    "TableColumnUpdate": {
      "title": "TableColumnUpdate",
      "type": "object",
      "properties": {
        "type": { "type": "string", "default": "sql" },
        "template": { "type": "string", "default": "" },
        "parameters": { "type": ["object", "null"], "default": null }
      }
    },
    "TableColumn": {
      "title": "TableColumn",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "header": { "type": "string" },
        "type": { "allOf": [{ "$ref": "#/$defs/ColumnType" }], "default": "text" },
        "sortable": { "type": "boolean", "default": true },
        "visible": { "type": "boolean", "default": true },
        "width": { "type": ["string", "null"], "default": null },
        "unit": { "type": ["string", "null"], "default": null },
        "color": { "type": ["string", "null"], "default": null, "description": "Column color: 'auto' for sign-based green/red, or explicit color string" },
        "update": { "allOf": [{ "$ref": "#/$defs/TableColumnUpdate" }], "default": null }
      },
      "required": ["id", "header"]
    },
    "TableRowMeta": {
      "title": "TableRowMeta",
      "description": "Optional metadata properties on table row objects",
      "type": "object",
      "properties": {
        "style": { "type": ["string", "null"], "enum": ["summary", "section", "total", null], "default": null, "description": "Row style: summary (bold+border), section (spanning header), total (bold+thick border)" },
        "indent": { "type": ["integer", "null"], "minimum": 0, "default": null, "description": "Visual indentation level (0-based)" }
      }
    },
    "TableHierarchy": {
      "title": "TableHierarchy",
      "type": "object",
      "properties": {
        "column_id": { "type": "string" },
        "mode": { "type": "string", "default": "numeric" }
      },
      "required": ["column_id"]
    },
    "TableQueryState": {
      "title": "TableQueryState",
      "type": "object",
      "properties": {
        "sort_column": { "type": ["string", "null"], "default": null },
        "sort_direction": { "type": "string", "default": "asc" },
        "page": { "type": "integer", "default": 0 },
        "page_size": { "type": "integer", "default": 20 },
        "total_count": { "type": ["integer", "null"], "default": null }
      }
    },
    "DWidgetBase": {
      "title": "DWidgetBase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": "string", "default": "0.2" },
        "description": { "type": "string", "default": "" },
        "type": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
        "xs": { "type": "array", "default": [] },
        "ys": { "type": "array", "default": [] },
        "unit": { "type": "string", "default": "HUF" },
        "digits": { "type": ["integer", "null"], "default": null },
        "prompt": { "type": "string", "default": "" },
        "template": { "type": "string", "default": "" },
        "query": { "type": ["array", "null"], "items": { "$ref": "#/$defs/QuerySource" }, "default": null },
        "selects": { "type": ["object", "null"], "default": null },
        "uses_parameters": { "type": "array", "items": { "type": "string" }, "default": [] },
        "last_requested": { "type": ["string", "null"], "format": "date-time", "default": null },
        "last_parameters": { "type": ["object", "null"], "default": null },
        "cache_error": { "type": ["string", "null"], "default": null }
      },
      "required": ["id", "title"]
    },
    "MetricScenario": {
      "title": "MetricScenario",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": ["number", "null"], "default": null },
        "color": { "type": ["string", "null"], "default": null }
      },
      "required": ["name"]
    },
    "MetricGoal": {
      "title": "MetricGoal",
      "type": "object",
      "properties": {
        "target": { "type": ["number", "null"], "default": null },
        "min": { "type": ["number", "null"], "default": null },
        "label": { "type": ["string", "null"], "default": null },
        "achieved": { "type": ["boolean", "null"], "default": null }
      }
    },
    "DWidgetMetricBase": {
      "title": "DWidgetMetricBase",
      "allOf": [
        { "$ref": "#/$defs/DWidgetBase" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["metric", "statistic"] },
            "value": { "type": ["number", "null"], "default": null },
            "subtitle": { "type": ["string", "null"], "default": null, "description": "Secondary text shown below the value, e.g. '-9.0% vs 2025'" },
            "comparison_value": { "type": ["number", "null"], "default": null, "description": "Previous period value for comparison" },
            "comparison_label": { "type": ["string", "null"], "default": null, "description": "Label for comparison value, e.g. '2025 már'" },
            "scenarios": { "type": ["array", "null"], "items": { "$ref": "#/$defs/MetricScenario" }, "default": null, "description": "Scenario comparison values" },
            "goal": { "allOf": [{ "$ref": "#/$defs/MetricGoal" }], "default": null, "description": "Goal tracking information" }
          },
          "required": ["type"]
        }
      ]
    },
    "DWidgetTableBase": {
      "title": "DWidgetTableBase",
      "allOf": [
        { "$ref": "#/$defs/DWidgetBase" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "table" },
            "xs": { "type": "array", "items": { "type": "string" } },
            "ys": { "type": "array", "items": { "type": "array", "items": { "anyOf": [{ "type": "string" }, { "type": "number" }] } } },
            "sorted": { "type": "string", "default": "asc" },
            "columns": { "type": "array", "items": { "$ref": "#/$defs/TableColumn" }, "default": [] },
            "hierarchy": { "allOf": [{ "$ref": "#/$defs/TableHierarchy" }], "default": null },
            "server_side": { "type": "boolean", "default": false },
            "default_page_size": { "type": "integer", "default": 20 },
            "pagination_enabled": { "type": "boolean", "default": true }
          },
          "required": ["type", "xs", "ys"]
        }
      ]
    },
    "DWidgetEChartBase": {
      "title": "DWidgetEChartBase",
      "allOf": [
        { "$ref": "#/$defs/DWidgetBase" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "echart" },
            "echart": { "type": "object", "default": {} }
          },
          "required": ["type"]
        }
      ]
    },
    "DWidgetHtmlBase": {
      "title": "DWidgetHtmlBase",
      "allOf": [
        { "$ref": "#/$defs/DWidgetBase" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "html" },
            "html": { "type": "string" }
          },
          "required": ["type", "html"]
        }
      ]
    },
    "DWidgetMarkdownBase": {
      "title": "DWidgetMarkdownBase",
      "allOf": [
        { "$ref": "#/$defs/DWidgetBase" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "markdown" },
            "markdown": { "type": "string" }
          },
          "required": ["type", "markdown"]
        }
      ]
    },
    "DDateBase": {
      "title": "DDateBase",
      "type": "object",
      "properties": {
        "year": { "type": "integer" },
        "month": { "type": "integer" },
        "day": { "type": "integer" }
      },
      "required": ["year", "month", "day"]
    },
    "DPeriodBase": {
      "title": "DPeriodBase",
      "type": "object",
      "properties": {
        "start": { "$ref": "#/$defs/DDateBase" },
        "end": { "$ref": "#/$defs/DDateBase" },
        "initial": { "type": "boolean", "default": false }
      },
      "required": ["start", "end"]
    }
  }
}
